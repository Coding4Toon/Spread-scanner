        ]
      ]
    },
    "Find Common Tokens": {
      "main": [
        [
          {
            "node": "Prepare Batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Batches": {
      "main": [
        [
          {
            "node": "Fetch Jupiter Prices",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Jupiter Prices": {
      "main": [
        [
          {
            "node": "Calculate Spreads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Calculate Spreads": {
      "main": [
        [
          {
            "node": "Has Spreads?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has Spreads?": {
      "main": [
        [
          {
            "node": "Fetch Jupiter Stats",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Jupiter Stats": {
      "main": [
        [
          {
            "node": "Log Scan",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Scan": {
      "main": [
        [
          {
            "node": "Build MEXC Auth",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build MEXC Auth": {
      "main": [
        [
          {
            "node": "Fetch MEXC Deposit Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch MEXC Deposit Status": {
      "main": [
        [
          {
            "node": "Enrich Spreads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Enrich Spreads": {
      "main": [
        [
          {
            "node": "Save Spread Alerts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "MEXC Futures Tickers": {
      "main": [
        [
          {
            "node": "Build MEXC Price Map",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "none"
  }
}